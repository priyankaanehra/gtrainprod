ault function MainContent(){\n    return (\n    <div className='container'>\n        <TwoRows ID1=\"oa96OPhV59s\" ID2=\"uTNp1TEOdkU\"/>\n        <TwoRows ID1=\"wXLjwMmNBz8\" ID2=\"iKrrCiFAse0\"/>\n        <TwoRows ID1=\"_-KfLxnZ4ro\" ID2=\"W19LseZHeis\"/>\n        <TwoRows ID1=\"HBanSeSQw0Q\" ID2=\"qTz-EA1o8pM\"/>\n    </div>\n    )\n}","/Users/priyankanehra/Desktop/gtrainprod/src/Footer.js",["47"],[],"import React from 'react';\nimport ReactDOM from 'react-dom';\nimport insta from './insta.png'\n\n\nexport default function Footer(){\n    return(\n        <div className='container copyright'>\n            <h3 className='allrights oswald'> © 2023 PNDEV. All Rights Reserved. </h3>\n            <a href=\"https://www.instagram.com/g_trainproductions/\">\n                <img src={insta} alt=\"logo\" className=\"insta-logo\"/>\n            </a>\n                \n                \n        </div>\n        )\n}\n","/Users/priyankanehra/Desktop/gtrainprod/src/TwoRows.js",["48"],[],"import React from \"react\";\nimport PropTypes from \"prop-types\";\nimport YoutubeEmbed from \"./YoutubeEmbed\";\n\n\nexport default function TwoRows(props) {\n    return (\n        <div className='row rowstyle'>\n            <div className='col-6 vid-item'>\n                <YoutubeEmbed embedId={props.ID1}/>\n            </div>\n            <div className='col-6 vid-item'>\n                <YoutubeEmbed embedId={props.ID2} />\n            </div>\n        </div>\n        \n    )\n}","/Users/priyankanehra/Desktop/gtrainprod/src/YoutubeEmbed.js",[],[],{"ruleId":"49","severity":1,"message":"50","line":3,"column":8,"nodeType":"51","messageId":"52","endLine":3,"endColumn":16},{"ruleId":"53","severity":1,"message":"54","line":13,"column":17,"nodeType":"55","endLine":13,"endColumn":57},{"ruleId":"53","severity":1,"message":"54","line":24,"column":17,"nodeType":"55","endLine":24,"endColumn":55},{"ruleId":"53","severity":1,"message":"54","line":25,"column":17,"nodeType":"55","endLine":25,"endColumn":55}