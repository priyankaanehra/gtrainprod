n                        <input type=\"email\" class=\"form-control\" id=\"name\" placeholder=\"\"/>\n                    </div>\n                    <div class=\"form-group col-md-6\">\n                        <label className='contacttitles' for=\"email\">Email</label>\n                        <input type=\"password\" class=\"form-control\" id=\"email\" placeholder=\"\"/>\n                    </div>\n                </div>\n                <div class=\"form-group\">\n                    <label className='contacttitles' for=\"subject\">Subject</label>\n                    <input type=\"text\" class=\"form-control\" id=\"subject\" placeholder=\"\"/>\n                </div>\n                <div class=\"form-group\">\n                    <label className='contacttitles' for=\"message\">Message</label>\n                    <input type=\"text\" class=\"form-control\" id=\"message\" placeholder=\"\"/>\n                </div>\n                <button type=\"submit\" class=\"btn btn-outline-light contactsubmit\">Submit</button>\n            </form>                            \n    </div>\n    )   \n}\n","/Users/priyankanehra/Desktop/gtrainprod/src/Pages/Home.js",["59"],[],"import React from 'react';\nimport ReactDOM from 'react-dom';\nimport '../App.css';\nimport MainContent from '../Components/MainContent';\n\nexport default function Home(){\n    return(\n        <div className='container'>\n            <MainContent/>                \n        </div>\n        )\n}\n","/Users/priyankanehra/Desktop/gtrainprod/src/Components/Footer.js",["60"],[],"import React from 'react';\nimport ReactDOM from 'react-dom';\nimport insta from '../Images/insta.png'\n\n\nexport default function Footer(){\n    return(\n        <div className='container copyright'>\n            <h3 className='allrights oswald'> © 2023 PNDEV. All Rights Reserved. </h3>\n            <a href=\"https://www.instagram.com/g_trainproductions/\">\n                <img src={insta} alt=\"logo\" className=\"insta-logo\"/>\n            </a>\n                \n                \n        </div>\n        )\n}\n","/Users/priyankanehra/Desktop/gtrainprod/src/Components/Header.js",["61"],[],"\nimport React from 'react';\nimport ReactDOM from 'react-dom';\nimport gtrainlogo from '../Images/logo.png'\nimport insta from '../Images/insta.png'\nimport hamburger from '../Images/hamburger.png'\n\n\nfunction Navbar() {\n    return (\n        <div role=\"banner\">\n        <nav className=\"navbar navbar-expand-lg mainnav\">\n            <div className='navleft'>\n                <a href=\"/\" className='navtitle oswald'>\n                <img src={gtrainlogo} alt=\"logo\" className=\"nav-logo\"/>\n                G-Train Productions\n                </a>\n            </div>\n            \n            <button class=\"navbar-toggler\" type=\"button\" data-bs-toggle=\"collapse\" data-bs-target=\"#navbarNavAltMarkup\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n            <img src={hamburger} alt=\"logo\" className=\"my-toggler\"/>\n            </button>\n            <div class=\"collapse navbar-collapse navright\" id=\"navbarNavAltMarkup\">\n                <div class=\"navbar-nav oswald navitems\">\n                <a className=\"nav-item nav-link\" href=\"/\">Home <span class=\"sr-only\">(current)</span></a>\n                <a className=\"nav-item nav-link\" href=\"/design\">Design</a>\n                <a className=\"nav-item nav-link\" href=\"/contact\">Contact</a>\n                <a className=\"nav-item nav-link\" href=\"https://www.instagram.com/g_trainproductions/\">\n                <img src={insta} alt=\"logo\" className=\"insta-logo-nav\"/>\n            </a>\n                </div>\n            </div>\n        </nav>\n        </div>\n    );\n  }\n  \n  export default Navbar;","/Users/priyankanehra/Desktop/gtrainprod/src/Components/TwoRows.js",["62"],[],"import React from \"react\";\nimport PropTypes from \"prop-types\";\nimport YoutubeEmbed from \"../Components/YoutubeEmbed\";\n\n\nexport default function TwoRows(props) {\n    return (\n        <div className='row rowstyle'>\n            <div className='col-6 vid-item'>\n                <YoutubeEmbed embedId={props.ID1}/>\n            </div>\n            <div className='col-6 vid-item'>\n                <YoutubeEmbed embedId={props.ID2} />\n            </div>\n        </div>\n        \n    )\n}","/Users/priyankanehra/Desktop/gtrainprod/src/Components/MainContent.js",["63","64"],[],"import React from 'react';\nimport ReactDOM from 'react-dom';\nimport YoutubeEmbed from \"../Components/YoutubeEmbed\";\nimport TwoRows from '../Components/TwoRows';\n\nexport default function MainContent(){\n    return (\n    <div className='container'>\n        <TwoRows ID1=\"oa96OPhV59s\" ID2=\"uTNp1TEOdkU\"/>\n        <TwoRows ID1=\"wXLjwMmNBz8\" ID2=\"iKrrCiFAse0\"/>\n        <TwoRows ID1=\"_-KfLxnZ4ro\" ID2=\"W19LseZHeis\"/>\n        <TwoRows ID1=\"HBanSeSQw0Q\" ID2=\"qTz-EA1o8pM\"/>\n    </div>\n    )\n}","/Users/priyankanehra/Desktop/gtrainprod/src/Components/YoutubeEmbed.js",[],[],{"ruleId":"65","severity":1,"message":"66","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":16},{"ruleId":"65","severity":1,"message":"66","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":16},{"ruleId":"65","severity":1,"message":"66","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":16},{"ruleId":"65","severity":1,"message":"66","line":3,"column":8,"nodeType":"67","messageId":"68","endLine":3,"endColumn":16},{"ruleId":"65","severity":1,"message":"69","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":17},{"ruleId":"65","severity":1,"message":"66","line":2,"column":8,"nodeType":"67","messageId":"68","endLine":2,"endColumn":16},{"ruleId":"65","severity":1,"message":"70","line":3,"column":8,"nodeType":"67","messageId":"68","endLine":3,"endColumn":20},"no-unused-vars","'ReactDOM' is d